# Admin authentication (required in deployed environments)
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
DASHBOARD_SESSION_SECRET=

# Persistent portfolio, recommendation, and validation storage
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Trusted portfolio-agnostic feed described in docs/ai-stock-intelligence.md
# Never configure a URL that requires sending user portfolio symbols or holdings.
MARKET_INTELLIGENCE_FEED_URL=

# Vercel Blob Storage — required in deployed environments for snapshot writes.
# Vercel auto-injects this when a Blob Store is connected to the project:
#   Dashboard → Storage → Create Blob Store → Connect to project
BLOB_READ_WRITE_TOKEN=

# Optional scheduled-route authorization
CRON_SECRET=
