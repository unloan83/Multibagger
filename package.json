{
  "name": "multibagger-portfolio-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "eslint app components lib",
    "csv:market-close": "node scripts/update_daily_recommendations.mjs --slot market-close",
    "csv:morning": "node scripts/update_daily_recommendations.mjs --slot morning",
    "csv:afternoon": "node scripts/update_daily_recommendations.mjs --slot afternoon",
    "intraday:gaps": "node scripts/analyze_intraday_gaps.mjs",
    "history:cleanup": "node scripts/cleanup_learning_history.mjs --apply",
    "universe:sync": "node scripts/sync_nifty500_universe.mjs",
    "wealth:snapshot": "node --import tsx scripts/run_wealth_snapshot.ts",
    "longterm:snapshot": "node --import tsx scripts/run_long_term_universe.ts",
    "test:wealth": "node --import tsx --test lib/expert-insights.test.ts lib/wealth-screening.test.ts lib/recommendation-intelligence.test.ts lib/learning-history.test.ts lib/model-evaluation.test.ts lib/stock-intelligence/recommendationCombiner.test.ts lib/agents/ipoAgent.test.ts lib/agents/multi-agent.test.ts lib/telegram.test.ts",
    "portfolio:backup": "node --import tsx scripts/export_portfolio_backup.ts",
    "portfolio:import-backup": "node --import tsx scripts/import_portfolio_backup.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "googleapis": "^173.0.0",
    "yahoo-finance2": "^3.15.4",
    "lucide-react": "^0.468.0",
    "next": "15.5.19",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.19",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}
